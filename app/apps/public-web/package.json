{
  "name": "@restorio/public-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:turbopack": "next dev -p 3000",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "deploy": "bun run build:cloudflare && wrangler pages deploy",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf .next",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" && eslint . --fix",
    "check": "prettier --check \"**/*.{ts,tsx,json,md}\" && eslint . --ext ts,tsx",
    "check:locales": "node scripts/check-locale-keys.mjs",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "vinext start"
  },
  "dependencies": {
    "@restorio/api-client": "workspace:*",
    "@restorio/auth": "workspace:*",
    "@restorio/types": "workspace:*",
    "@restorio/ui": "workspace:*",
    "@restorio/utils": "workspace:*",
    "react": "19",
    "react-dom": "19",
    "react-icons": "^5.5.0",
    "react-intl": "^10.1.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@opennextjs/cloudflare": "^1.19.8",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.10.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.26",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.35",
    "react-server-dom-webpack": "^19.2.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9",
    "vinext": "^0.0.49",
    "vite": "^7.3.2",
    "vitest": "^4.0.16",
    "wrangler": "^4.90.0"
  },
  "type": "module"
}
