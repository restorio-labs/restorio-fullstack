# Database Configuration (host / IDE / pytest — not copied into Compose by default)
DATABASE_URL=mongodb+atlas://username:password@cluster.mongodb.net/restorio?retryWrites=true&w=majority
# For local MongoDB: mongodb://localhost:27017/restorio

COMPOSE_DATABASE_URL=mongodb://mongo:27017/restorio?authSource=admin
COMPOSE_POSTGRES_DSN=postgresql://restorio:restorio@postgres:5432/restorio
COMPOSE_MINIO_ENDPOINT=minio:9000

MONGODB_USERNAME=restorio
MONGODB_PASSWORD=restorio

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Przelewy24 Payment Provider
PRZELEWY24_MERCHANT_ID=your_merchant_id
PRZELEWY24_POS_ID=your_pos_id
PRZELEWY24_CRC=your_crc_key
PRZELEWY24_API_KEY=your_api_key

# Resend Email Provide
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=your_from_email

ENV=development

# Minio Configuration
MINIO_ACCESS_KEY=restorio
MINIO_SECRET_KEY=restorio
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PUBLIC_SECURE=false
MINIO_REGION=us-east-1

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=